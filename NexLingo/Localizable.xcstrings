    "请求被拒绝或网络异常，请检查 API Key是否有效。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Request denied or network error. Please check if your API Key is valid."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अनुरोध अस्वीकृत कर दिया गया या नेटवर्क त्रुटि, कृपया जांचें कि आपकी API Key मान्य है या नहीं।"
          }
        },
        "ko" : {
